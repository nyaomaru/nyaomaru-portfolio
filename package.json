    "lefthook": "^2.1.4",
    "oxfmt": "^0.28.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^6.4.1",
    "vite-tsconfig-paths": "^4.3.2",
    "vitest": "^3.2.4"
