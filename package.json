{
  "name": "nyaomaru-portfolio",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "remix vite:build",
    "dev": "remix vite:dev",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint --no-warn-ignored .",
    "prepare": "lefthook install",
    "start": "remix-serve ./build/server/index.js",
    "typecheck": "tsc",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "fmt": "oxfmt --ignore-path .gitignore --ignore-path .oxfmtignore .",
    "fmt:check": "oxfmt --check --ignore-path .gitignore --ignore-path .oxfmtignore ."
  },
  "dependencies": {
    "@fontsource-variable/source-sans-3": "^5.2.9",
